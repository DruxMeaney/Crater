{
  "name": "crater",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "app": "npm run build && electron .",
    "app:dev": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "app:smoke": "CRATER_SMOKE=1 electron .",
    "dist:app": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.drux.crater",
    "productName": "Crater",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  }
}
